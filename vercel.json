{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/index.go": {
      "includeFiles": [
        "map.json",
        "api/map.json"
      ],
      "regions": [
        "hkg1"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/index",
      "destination": "/api/index.go"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.go"
    },
    {
      "source": "/",
      "destination": "/api/index.go"
    }
  ]
}
